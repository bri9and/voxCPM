# VoxCPM Model (optional, defaults to openbmb/VoxCPM1.5)
VOXCPM_MODEL=openbmb/VoxCPM1.5

# API Port (optional, defaults to 5001)
API_PORT=5001

# API Secret Key — shared between Next.js and Flask for authentication.
# Set this to a random string (e.g., openssl rand -hex 32).
# If unset, authentication is disabled (dev mode only).
API_SECRET_KEY=

# Rate limiting (optional, defaults shown)
# RATE_LIMIT_MAX=10        # max requests per window
# RATE_LIMIT_WINDOW=60     # window size in seconds
